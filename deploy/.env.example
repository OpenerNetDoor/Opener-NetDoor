COMPOSE_PROJECT_NAME=openernetdoor

POSTGRES_DB=openernetdoor
POSTGRES_USER=openernetdoor
POSTGRES_PASSWORD=change_me

JWT_ISSUER=opener-netdoor
JWT_AUDIENCE=opener-netdoor-api
JWT_SECRET=change_me_very_long_random_value

NODE_SIGNING_SECRET=change_me_node_signing_secret
NODE_CONTRACT_VERSION=2026-03-10.stage5.v1
NODE_PKI_MODE=strict
NODE_CA_MODE=file
NODE_CA_ACTIVE_ISSUER_ID=default-file-issuer
NODE_CA_PREVIOUS_ISSUER_IDS=
NODE_CA_CERT_PATH=
NODE_CA_KEY_PATH=
NODE_CERT_RENEW_BEFORE=168h
NODE_CERT_DEFAULT_TTL=720h
NODE_CERT_MAX_TTL=720h
NODE_LEGACY_HMAC_FALLBACK=false

DEPLOY_MODE=ip
PUBLIC_HOST=127.0.0.1
PUBLIC_BASE_URL=http://127.0.0.1
HTTPS_ENABLED=false
LETSENCRYPT_EMAIL=

OWNER_SUBJECT=owner
OWNER_EMAIL=owner@example.com
OWNER_SCOPE_ID=
OWNER_SCOPE_NAME=Default Owner Scope
OWNER_TOKEN_TTL_HOURS=720
OWNER_BOOTSTRAP_TOKEN_FILE=./state/owner-bootstrap-token.txt
