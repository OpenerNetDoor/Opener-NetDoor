COMPOSE_PROJECT_NAME=openernetdoor

POSTGRES_DB=openernetdoor
POSTGRES_USER=openernetdoor
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

REDIS_PORT=6379
NATS_PORT=4222

API_GATEWAY_PORT=8080
CORE_PLATFORM_PORT=8081

JWT_ISSUER=opener-netdoor
JWT_AUDIENCE=opener-netdoor-api
JWT_SECRET=change_me_very_long_random_value

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_me_now

DOMAIN=
LETSENCRYPT_EMAIL=

NODE_PKI_MODE=strict
NODE_CA_MODE=file
NODE_CA_ACTIVE_ISSUER_ID=default-file-issuer
NODE_CA_PREVIOUS_ISSUER_IDS=
NODE_CA_CERT_PATH=
NODE_CA_KEY_PATH=
NODE_CERT_RENEW_BEFORE=168h
NODE_CERT_DEFAULT_TTL=720h
NODE_CERT_MAX_TTL=720h
NODE_LEGACY_HMAC_FALLBACK=false

NODE_AGENT_TENANT_ID=00000000-0000-0000-0000-000000000001
NODE_AGENT_ID=node-local-1
NODE_AGENT_KEY_ID=node-key-local-1
NODE_AGENT_PUBLIC_KEY=node-public-key-local

OPENER_NETDOOR_COMPOSE_FILE=docker-compose.yml
OPENER_NETDOOR_ENV_FILE=.env
OPENER_NETDOOR_GATEWAY_URL=http://127.0.0.1:8080
OPENER_NETDOOR_BACKUP_DIR=ops/backups
